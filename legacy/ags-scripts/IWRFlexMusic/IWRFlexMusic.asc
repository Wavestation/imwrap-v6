// =============================================================================
//  IWRFlexMusic.asc  —  Module script
//  Multi-Sequence interactive music manager for AGS + agsimwrap
// =============================================================================

int _pendingTargetSoundId = -1;
int _currentPlayingSoundId = -1;
int _silentFallbackTimer = 0;

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.Play()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::Play(int soundId)
{
  if (!iMWrap_IsSoundActive(soundId))
  {
    // Abort any pending transition
    _pendingTargetSoundId = -1;
    _currentPlayingSoundId = soundId;
    
    iMWrap_StartSound(soundId);
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::Play : SoundId %d",
    soundId));
  }
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.Stop()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::Stop(int soundId)
{
    // Abort any pending transition
    _pendingTargetSoundId = -1;
    if (_currentPlayingSoundId == soundId) 
    {
        _currentPlayingSoundId = -1;
    }
    
    iMWrap_StopSound(soundId);
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::Stop : SoundId %d",
    soundId));
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.SetTransition()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::SetTransition(int currentSoundId, int targetSoundId, int hookValue)
{
    // Always update the pending target. If a transition is ALREADY in progress
    // (e.g. from rapid room switching), this elegantly "redirects" the landing
    // to the newly requested track.
    _pendingTargetSoundId = targetSoundId;
    
    // To avoid the race condition where iMWrap_IsSoundActive returns false 
    // because the sound was JUST started, we compare with our own tracking 
    // variable _currentPlayingSoundId. If it matches, we arm the Hook.
    if (currentSoundId == _currentPlayingSoundId || iMWrap_IsSoundActive(currentSoundId))
    {
        // Clear loop on the current sound so the playhead can proceed to the Hook
        iMWrap_ClearLoop(currentSoundId);
        
        // Arm the Hook Jump (class 48 = 0x30)
        iMWrap_SetHook(currentSoundId, IMWRAP_HOOK_JUMP, hookValue, 0);
    }
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::SetTransition : currentSoundId %d targetSoundId %d hookVal %d",
    currentSoundId,
    targetSoundId, 
    hookValue));
}

// ---------------------------------------------------------------------------
//  AUTOMATIC UPDATE LOOP
//
//  AGS automatically calls repeatedly_execute_always for every script module.
//  We use it here to process queued markers and handle automatic transitions
//  without requiring the user to add code to their Global Script.
// ---------------------------------------------------------------------------
function repeatedly_execute_always()
{
    int packed = iMWrap_PopMarker();
    while (packed != -1)
    {
        int markerId = packed & 0xFF;
        int soundId = (packed >> 8) & 0xFFFFFF;
        
        // -----------------------------------------------------------------------
        //  AUTOMATIC TRANSITION RESOLUTION (Marker 64)
        // -----------------------------------------------------------------------
        if (markerId == 64 && _pendingTargetSoundId != -1)
        {
            System.Log(eLogInfo, String.Format(
            "IWRFlexMusic::Update : soundId %d markerId %d targetId %d",
            soundId,
            markerId, 
            _pendingTargetSoundId));
            
            // Read the target and clear the pending flag BEFORE starting the sound,
            // to prevent any accidental re-entrance.
            int target = _pendingTargetSoundId;
            _pendingTargetSoundId = -1;
            
            // 2. Start the new sequence
            _currentPlayingSoundId = target;
            iMWrap_StartSound(target);
        }
        
        packed = iMWrap_PopMarker();
    }
    
    // -----------------------------------------------------------------------
    //  FALLBACK ANTI-PERTE DE MARQUEUR (ex: flush lors d'un changement de room)
    // -----------------------------------------------------------------------
    // Si une transition est en attente, mais que la musique source a cessé de jouer
    // (son track de transition est terminé) et que le Marker 64 n'a jamais été 
    // intercepté (parce qu'un changement de room a vidé la file d'attente du plugin),
    // nous forçons le démarrage après un court délai de sécurité (pour éviter les faux-positifs
    // liés au temps de chargement du moteur audio).
    if (_pendingTargetSoundId != -1 && _currentPlayingSoundId != -1)
    {
        if (!iMWrap_IsSoundActive(_currentPlayingSoundId))
        {
            _silentFallbackTimer++;
            if (_silentFallbackTimer > 5) // 5 frames (~125ms) de tolérance
            {
                System.Log(eLogInfo, "IWRFlexMusic: Marker 64 perdu (changement de room) ! Démarrage forcé de la cible.");
                int target = _pendingTargetSoundId;
                _pendingTargetSoundId = -1;
                _currentPlayingSoundId = target;
                _silentFallbackTimer = 0;
                
                iMWrap_StartSound(target);
            }
        }
        else
        {
            _silentFallbackTimer = 0;
        }
    }
    else
    {
        _silentFallbackTimer = 0;
    }
}
