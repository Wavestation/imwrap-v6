// room script file

function room_FirstLoad()
{
  Doors.SetDoorState(10, 2);
  Doors.InitObject(10, oDoor.ID);
}

function hDoor_AnyClick(Hotspot *thisHotspot, CursorMode mode)
{
  if ( Doors.AnyClickSpecial(10, oDoor.ID, 313, 165, eDirectionUp, 1, 210, 145, eDirectionUp, null, null, 3, 0) == 0 ) Verbs.Unhandled();
}

function hProjector_AnyClick(Hotspot *thisHotspot, CursorMode mode)
{
  if (Verbs.UsedAction(eGA_LookAt)) 
  {
    player.Say("It is a projector for the holographic illusions and a vanishing point.");
  }
  else if (Verbs.UsedAction(eGA_Push) || Verbs.UsedAction(eGA_Pull))
  {  
    iMWrap_StartSound(SFX_DOOR_OPEN);
    player.Say("What's happening?!?");
    
    if (iMWrap_IsSoundActive(MUSIC_HOLODECK))
    {
      System.Log(eLogInfo,  "Initializing fast detune effect");
      
      // Start detune and slow down effect (30 time loops)
      for (int transpose = 1; transpose >= -28; transpose--) 
      {
          for (int detune = 5; detune >= -64; detune -= 21) 
          {
              iMWrap_SetSoundDetune(MUSIC_HOLODECK, detune);
              System.Log(eLogInfo, String.Format("detune %d", detune));
              Wait(1); 
          }
          
          // Reset detune and apply transpose
          iMWrap_SetSoundDetune(MUSIC_HOLODECK, 0);
          iMWrap_SetSoundTranspose(MUSIC_HOLODECK, 0, transpose);
          
          // Tempo map
          int tempo = ((transpose + 28) * 128) / 29;
          iMWrap_SetSoundSpeed(MUSIC_HOLODECK, tempo + 1);
          
          // Desature characters for visual effects
          int saturation = 100 - ((tempo * 100) / 128); 
          SetAmbientTint(128, 128, 128, saturation, 100);
       
          // Logging
          System.Log(eLogInfo, String.Format("transpo %d, tempo %d", transpose,  tempo));
          System.Log(eLogInfo, String.Format("saturation %d",  saturation));
      }
      
      player.Say("Oh I broke the projector?!?");
      Wait(39);
      cHologram.Say("Gasp...");
      Wait(39);
      player.FaceDirection(eDirectionRight);
      player.Say("Let's repair it ...");
      player.FaceDirection(eDirectionUp);
      Wait(96);
      SetAmbientTint(0, 0, 0, 0, 100);
      iMWrap_StartSound(SFX_DOOR_CLOSE);
      iMWrap_SetSoundSpeed(MUSIC_HOLODECK, 128);
      iMWrap_SetSoundTranspose(MUSIC_HOLODECK, 0, 0);
      iMWrap_SetSoundDetune(MUSIC_HOLODECK, 0);
      player.FaceDirection(eDirectionDown);
      player.Say("Whew! I think it's OK now!");
    }
    else
    {
      System.Log(eLogInfo,  "MUSIC_HOLODECK is not playing");
    }
  }
  else Verbs.Unhandled();
}

function room_Load()
{
  //aHolodeckDoor.SetView(VHOLODECKDOOR);
  
  // Put the Base to Holodeck transition in the queue
  iMWrap_ClearQueue();
  iMWrap_QueueTrigger(MUSIC_BASEROOM, 64);
  iMWrap_QueueStartSound(MUSIC_BASEROOM, MUSIC_HOLODECK);
  iMWrap_CommitQueue(MUSIC_BASEROOM);
  
  iMWrap_SetJumpHook(MUSIC_BASEROOM, JH_BASE_TO_HOLO);
  
  // anti-silence failback
  if (iMWrap_GetActiveSoundCount() == 0) iMWrap_StartSound(MUSIC_HOLODECK);
}

function room_Leave()
{
  // Put the transition in the queue
  iMWrap_ClearQueue(); 
  iMWrap_QueueTrigger(MUSIC_HOLODECK, 64);
  iMWrap_QueueStartSound(MUSIC_HOLODECK, MUSIC_BASEROOM);
  iMWrap_CommitQueue(MUSIC_HOLODECK);
  
  iMWrap_SetJumpHook(MUSIC_HOLODECK, JH_HOLO_TO_BASE);
}
