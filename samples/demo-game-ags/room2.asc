// room script file

function room_FirstLoad()
{
  Doors.SetDoorState(10, 2);
  Doors.InitObject(10, oDoor.ID);
}

function hDoor_AnyClick(Hotspot *thisHotspot, CursorMode mode)
{
  if ( Doors.AnyClickSpecial(10, oDoor.ID, 313, 165, eDirectionUp, 1, 210, 145, eDirectionUp, null, null, 3, 0) == 0 ) Verbs.Unhandled();
}

function hProjector_AnyClick(Hotspot *thisHotspot, CursorMode mode)
{
  if (Verbs.UsedAction(eGA_LookAt)) 
  {
    player.Say("It is a projector for the holographic illusions and a vanishing point.");
  }
  else Verbs.Unhandled();
}

function room_Load()
{
  // Put the Base to Holodeck transition in the queue
  iMWrap_ClearQueue();
  
  iMWrap_QueueTrigger(MUSIC_BASEROOM, 64);
  iMWrap_QueueCommand(MUSIC_BASEROOM, IMWRAP_CMD_START_SOUND, MUSIC_HOLODECK);
  iMWrap_CommitQueue(MUSIC_BASEROOM);
  
  iMWrap_SetHook(MUSIC_BASEROOM, IMWRAP_HOOK_JUMP, JH_BASE_TO_HOLO, 0);
  
  // Old manneer
  //IWRFlexMusic.SetTransition(MUSIC_BASEROOM, MUSIC_HOLODECK, JH_BASE_TO_HOLO);
}

function room_Leave()
{
  iMWrap_ClearQueue();
  
  iMWrap_QueueTrigger(MUSIC_HOLODECK, 64);
  iMWrap_QueueCommand(MUSIC_HOLODECK, IMWRAP_CMD_START_SOUND, MUSIC_BASEROOM);
  iMWrap_CommitQueue(MUSIC_HOLODECK);
  
  iMWrap_SetHook(MUSIC_HOLODECK, IMWRAP_HOOK_JUMP, JH_HOLO_TO_BASE, 0);
  
  // Put the Holodeck to Base transition in the queue
  //IWRFlexMusic.SetTransition(MUSIC_HOLODECK, MUSIC_BASEROOM, JH_HOLO_TO_BASE);
}
