// =============================================================================
//  DemoMusicManager.ash
//  Music Manager for the demo game
// =============================================================================


void music_init()
{
  // Enable Debug Mode
  iMWrap_EnableLog(true);
  
  // Perform master settings
  iMWrap_SetWelcomeMessage("iMWrap MT-32 Loading");
  int midiVolume = 80 * 127 / 100;
  iMWrap_SetMasterVolume(midiVolume);
  
  
  // Engine Init : Uncomment one of the sections below according to your actual device
  
  // Software GM using FluidSynth SoundFont engine
  if (System.OperatingSystem == eOSWeb) 
  {
    iMWrap_SetSFDynLoad(false);
  }
  else
  {
    iMWrap_SetSFDynLoad(true);
  }

  iMWrap_SetDriver(IMWRAP_DRIVER_FLUIDSYNTH, SF2_BANK);
  
  // Hardware GM Module (e.g. Roland SC-55, Yamaha MU128, Korg NS5R)
  // iMWrap_SetDriver(IMWRAP_DRIVER_HARDWARE_GM, MIDI_OUT_GMD);
  
  // Roland MT-32
  // iMWrap_SetDriver(IMWRAP_DRIVER_HARDWARE_MT32, MIDI_OUT_MT32);
  
  
  // Load music pack
  iMWrap_LoadBank(IMS_PACK);
  
}