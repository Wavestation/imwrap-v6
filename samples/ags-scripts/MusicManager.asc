// =============================================================================
//  MusicManager.asc  —  Module script  (v2 — Generic / Drop-in)
//  States and Sequences system for AGS + agsimwrap plugin
//
//  THIS FILE CONTAINS NO PROJECT-SPECIFIC DATA.
//  All configuration is injected from game_start() via
//  MusicManager.Init(), .RegisterState() and .RegisterSequence().
//
//  ARCHITECTURE
//  ============
//  Two internal tables (size MUSIC_MAX_STATES / MUSIC_MAX_SEQUENCES):
//    • _states[]    : MusicStateData — entry point of each state
//    • _sequences[] : MusicSequenceData — bridge + hookValue of each transition
//
//  Music loops for each state are handled by the iMWrap engine via the
//  0x50 SysEx (Set Loop) embedded in the .ims by the composer.
//  The script only knows the entry point (entryBeat) — nothing else.
//
//  EXECUTION FLOW
//  ==============
//
//  ┌─ SetState(stateId) ──────────────────────────────────────────────────┐
//  │  1. iMWrap_ClearLoop()      — clears the previous loop              │
//  │  2. iMWrap_Jump(entryBeat)  — seeks to the start of the section     │
//  │     └─ Engine reads SysEx 0x50 and arms the loop automatically      │
//  └──────────────────────────────────────────────────────────────────────┘
//
//  ┌─ Transition(seqId, targetStateId) ───────────────────────────────────┐
//  │  1. Stores targetStateId in _pendingStateId                          │
//  │  2. iMWrap_ClearLoop()   — releases the current loop                │
//  │  3a. Hook mode  (hookValue > 0):                                     │
//  │      iMWrap_SetHook(hookClass=0x30, hookValue=seq.hookValue)         │
//  │      → Engine waits for the matching Hook Jump SysEx in the MIDI     │
//  │        to jump to the bridge (target track encoded in the SysEx)     │
//  │  3b. Direct mode (hookValue == 0):                                   │
//  │      iMWrap_Jump(seq.trackId, seq.startBeat, seq.startTick)          │
//  │      → Immediate seek to the bridge, no SysEx Hook needed            │
//  └──────────────────────────────────────────────────────────────────────┘
//
//  ┌─ iMWrap_OnTrigger(soundId, markerId) ────────────────────────────────┐
//  │  If markerId == _transitionMarkerId && _transitionPending            │
//  │    → SetState(_pendingStateId)   — automatic resolution              │
//  └──────────────────────────────────────────────────────────────────────┘
//
//  agsimwrap API signatures (quick reference)
//  -------------------------------------------
//    iMWrap_ClearLoop(soundId)
//    iMWrap_Jump(soundId, track, beat, tick)
//    iMWrap_SetHook(soundId, hookClass, hookValue, hookChannel)
//      hookClass = 48 (0x30) for a Hook Jump
//      hookValue = CMD value of the 0x30 SysEx in the MIDI
//    iMWrap_StopSound(soundId)
// =============================================================================

// ---------------------------------------------------------------------------
//  PRIVATE MODULE VARIABLES
// ---------------------------------------------------------------------------

// ID of the controlled sound (iMWrap soundId), set by Init().
int _soundId;

// ID of the MIDI marker that signals the end of a transition bridge.
// Set by Init(). Matches the useful byte of: F0 7D 40 00 [X] F7
int _transitionMarkerId;

// Current state (MusicStateId value) or STATE_NONE.
int _currentStateId;

// State to switch to after the current bridge ends.
// Equals STATE_NONE when no transition is pending.
int _pendingStateId;

// true while a transition bridge is being played.
bool _transitionPending;

// Data tables — populated via RegisterState() / RegisterSequence().
MusicStateData    _states[MUSIC_MAX_STATES];
MusicSequenceData _sequences[MUSIC_MAX_SEQUENCES];

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.Init()
// ---------------------------------------------------------------------------

static void MusicManager::Init(int soundId, int transitionEndMarkerId)
{
    // Store the identifiers provided by the game.
    _soundId            = soundId;
    _transitionMarkerId = transitionEndMarkerId;

    // Reset internal state.
    _currentStateId    = STATE_NONE;
    _pendingStateId    = STATE_NONE;
    _transitionPending = false;

    // Invalidate all table entries.
    int i;
    for (i = 0; i < MUSIC_MAX_STATES; i++) {
        _states[i].registered = false;
    }
    for (i = 0; i < MUSIC_MAX_SEQUENCES; i++) {
        _sequences[i].registered = false;
    }
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.RegisterState()
// ---------------------------------------------------------------------------

static void MusicManager::RegisterState(int stateId, int trackId, int entryBeat, int entryTick)
{
    // Silent rejection if the index is out of bounds.
    if (stateId < 0 || stateId >= MUSIC_MAX_STATES) {
        return;
    }

    _states[stateId].trackId    = trackId;
    _states[stateId].entryBeat  = entryBeat;
    _states[stateId].entryTick  = entryTick;
    _states[stateId].registered = true;
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.RegisterSequence()
// ---------------------------------------------------------------------------

static void MusicManager::RegisterSequence(int seqId, int trackId, int startBeat, int startTick, int hookValue)
{
    // Silent rejection if the index is out of bounds.
    if (seqId < 0 || seqId >= MUSIC_MAX_SEQUENCES) {
        return;
    }

    _sequences[seqId].trackId    = trackId;
    _sequences[seqId].startBeat  = startBeat;
    _sequences[seqId].startTick  = startTick;
    _sequences[seqId].hookValue  = hookValue;
    _sequences[seqId].registered = true;
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.SetState()
// ---------------------------------------------------------------------------

static void MusicManager::SetState(int stateId)
{
    // Silent rejection if the state has not been registered.
    if (stateId < 0 || stateId >= MUSIC_MAX_STATES) {
        return;
    }
    if (!_states[stateId].registered) {
        return;
    }

    // 1. Clear the previous loop.
    //    Required: without this, the old loop would short-circuit the Jump.
    iMWrap_ClearLoop(_soundId);

    // 2. Seek to the entry point of the target state on its track.
    //    trackId = 0  → classic single-track layout (all states on track 0)
    //    trackId > 0  → each state has its own MIDI track
    //    The iMWrap engine reads the 0x50 SysEx in this section and arms
    //    the loop automatically — no iMWrap_SetLoop() call needed here.
    iMWrap_Jump(_soundId, _states[stateId].trackId, _states[stateId].entryBeat, _states[stateId].entryTick);

    // 3. Update internal state.
    _currentStateId    = stateId;
    _transitionPending = false;
    _pendingStateId    = STATE_NONE;
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.GetCurrentState()
// ---------------------------------------------------------------------------

static int MusicManager::GetCurrentState()
{
    return _currentStateId;
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.Transition()
// ---------------------------------------------------------------------------

static void MusicManager::Transition(int seqId, int targetStateId)
{
    // Silent rejection if the sequence has not been registered.
    if (seqId < 0 || seqId >= MUSIC_MAX_SEQUENCES) {
        return;
    }
    if (!_sequences[seqId].registered) {
        return;
    }

    // Silent rejection if the target state has not been registered.
    if (targetStateId < 0 || targetStateId >= MUSIC_MAX_STATES) {
        return;
    }
    if (!_states[targetStateId].registered) {
        return;
    }

    // Prevent stacking two simultaneous transitions.
    if (_transitionPending) {
        return;
    }

    // 1. Store the destination before any plugin call.
    //    (iMWrap_SetHook may fire almost immediately if the SysEx is very
    //    close to the current playhead position in the MIDI.)
    _pendingStateId    = targetStateId;
    _transitionPending = true;

    // 2. Release the current state's loop.
    iMWrap_ClearLoop(_soundId);

    // 3a. HOOK MODE (hookValue > 0) — synchronized transition
    //     Arms the iMWrap engine to execute the Hook Jump SysEx present in
    //     the current state's track at the next opportune musical moment.
    //     The 0x30 SysEx in the MIDI encodes the bridge's target track itself:
    //       F0 7D 30 00 [hookValue] [TARGET_TRACK] [BEAT] [TICK] F7
    //     The script does not need to know the bridge's track in Hook mode.
    //
    //     Parameters:
    //       hookClass   = 48 (0x30) — "Hook Jump" type
    //       hookValue   = CMD value defined in RegisterSequence()
    //       hookChannel = 0  — logical channel (0 suits most cases)
    //
    //     ⚠  Each sequence must use a unique hookValue to prevent a Hook Jump
    //        from firing the wrong transition.
    //
    // 3b. DIRECT JUMP MODE (hookValue == 0) — immediate transition
    //     Useful when the MIDI does not contain a 0x30 Hook Jump SysEx,
    //     or when bar-level synchronization is not required.
    //     iMWrap_Jump() seeks immediately to the bridge's track and measure.

    if (_sequences[seqId].hookValue != 0)
    {
        // HOOK MODE
        iMWrap_SetHook(_soundId, 48, _sequences[seqId].hookValue, 0);
    }
    else
    {
        // DIRECT JUMP MODE
        //   Uses the sequence's trackId to target the correct bridge track.
        //   Typical when bridges live on a separate track (e.g. track 1)
        //   and no Hook Jump SysEx is embedded in the MIDI.
        iMWrap_Jump(_soundId,
                    _sequences[seqId].trackId,
                    _sequences[seqId].startBeat,
                    _sequences[seqId].startTick);
    }
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.IsTransitionPending()
// ---------------------------------------------------------------------------

static bool MusicManager::IsTransitionPending()
{
    return _transitionPending;
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: MusicManager.Stop()
// ---------------------------------------------------------------------------

static void MusicManager::Stop()
{
    iMWrap_ClearLoop(_soundId);
    iMWrap_StopSound(_soundId);

    _currentStateId    = STATE_NONE;
    _pendingStateId    = STATE_NONE;
    _transitionPending = false;
}

// ---------------------------------------------------------------------------
//  GLOBAL CALLBACK: iMWrap_OnTrigger
//
//  Called automatically by the agsimwrap plugin when the engine encounters
//  a MIDI Marker (SysEx 0x40) in the .ims file.
//
//  ⚠  IMPORTANT — Integration in your AGS project:
//     This function must live in your project's Global Script (.asc).
//     It cannot be declared in two different files.
//
//     If you already use iMWrap_OnTrigger in your Global Script, copy only
//     the "TRANSITION RESOLUTION" block below into your existing function.
//
//  Recommended marker convention:
//    • transitionEndMarkerId (e.g. 99): end of a bridge → automatic resolution
//    • Any other value: free gameplay synchronization (animations, dialogue…)
// ---------------------------------------------------------------------------
function iMWrap_OnTrigger(int soundId, int markerId)
{
    // -----------------------------------------------------------------------
    //  TRANSITION RESOLUTION — MusicManager block
    //  (copy this block into your iMWrap_OnTrigger if needed)
    // -----------------------------------------------------------------------
    if (soundId == _soundId && markerId == _transitionMarkerId)
    {
        if (_transitionPending && _pendingStateId != STATE_NONE)
        {
            // Read the destination before resetting the flags,
            // since SetState() sets _transitionPending back to false.
            int nextState = _pendingStateId;

            // Reset upfront to prevent any re-entrance.
            _transitionPending = false;
            _pendingStateId    = STATE_NONE;

            MusicManager.SetState(nextState);
        }
        return;
    }

    // -----------------------------------------------------------------------
    //  FREE ZONE — add your own gameplay synchronizations here
    //
    //  Example:
    //    if (soundId == _soundId && markerId == 10) {
    //        cHero.Animate(3, 2, eOnce, eNoBlock);
    //    }
    // -----------------------------------------------------------------------
}

// ---------------------------------------------------------------------------
//  END OF MODULE MusicManager
// ---------------------------------------------------------------------------
