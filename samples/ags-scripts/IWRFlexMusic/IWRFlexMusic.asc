// =============================================================================
//  IWRFlexMusic.asc  —  Module script
//  Multi-Sequence interactive music manager for AGS + agsimwrap
// =============================================================================

int _pendingTargetSoundId = -1;

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.SetTransition()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::SetTransition(int currentSoundId, int targetSoundId, int hookValue)
{
    _pendingTargetSoundId = targetSoundId;
    
    // Clear loop on the current sound so the playhead can proceed to the Hook
    iMWrap_ClearLoop(currentSoundId);
    
    // Arm the Hook Jump (class 48 = 0x30)
    iMWrap_SetHook(currentSoundId, IMWRAP_HOOK_JUMP, hookValue, 0);
    
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::SetTransition : currentSoundId %d targetSoundId %d hookVal %d",
    currentSoundId,
    targetSoundId, 
    hookValue));
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.Play()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::Play(int soundId)
{
  if (!iMWrap_IsSoundActive(soundId))
  {
    // Abort any pending transition
    _pendingTargetSoundId = -1;
    
    iMWrap_StartSound(soundId);
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::Play : SoundId %d",
    soundId));
  }
}

// ---------------------------------------------------------------------------
//  IMPLEMENTATION: IWRFlexMusic.Stop()
// ---------------------------------------------------------------------------
static void IWRFlexMusic::Stop(int soundId)
{
    // Abort any pending transition
    _pendingTargetSoundId = -1;
    
    iMWrap_StopSound(soundId);
    
    System.Log(eLogInfo, String.Format(
    "IWRFlexMusic::Stop : SoundId %d",
    soundId));
}

// ---------------------------------------------------------------------------
//  GLOBAL CALLBACK: IWRFlexMusic::OnTrigger
//
//  Called automatically by the agsimwrap plugin when the engine encounters
//  a MIDI Marker (SysEx 0x40) in the .ims file.
//
//  ⚠  IMPORTANT — Integration in your AGS project:
//     This function must live in your project's Global Script (.asc).
//     It cannot be declared in two different files.
//
//     If you already use iMWrap_OnTrigger in your Global Script, copy only
//     the content of this function into your existing function.
// ---------------------------------------------------------------------------
static function IWRFlexMusic::OnTrigger(int soundId, int markerId)
{
    // -----------------------------------------------------------------------
    //  AUTOMATIC TRANSITION RESOLUTION (Marker 64)
    // -----------------------------------------------------------------------
    if (markerId == 64 && _pendingTargetSoundId != -1)
    {
        System.Log(eLogInfo, String.Format(
        "IWRFlexMusic::OnTrigger : soundId %d markerId %d targetId %d",
        soundId,
        markerId, 
        _pendingTargetSoundId));
        
        // Read the target and clear the pending flag BEFORE starting the sound,
        // to prevent any accidental re-entrance.
        int target = _pendingTargetSoundId;
        _pendingTargetSoundId = -1;
        
        // Stop the current transitioning sequence 
        // -- useless because we suppose the Marker ID 64 
        // -- was put at the end of transition track
        // iMWrap_StopSound(soundId);
        
        // 2. Start the new sequence
        iMWrap_StartSound(target);
        return;
    }
}
